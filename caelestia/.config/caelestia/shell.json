{
    "appearance": {
        "font": {
            "family": {
                "material": "Material Symbols Rounded",
                "mono": "Adwaita Sans",
                "sans": "Adwaita Sans"
            }
        }
    },
    "bar": {
        "status": {
            "showAudio": true,
            "showKbLayout": false,
            "showMicrophone": false
        }
    },
    "dashboard": {
        "showOnHover": true
    },
    "general": {
        "apps": {
            "audio": [
                "pavucontrol"
            ],
            "explorer": [
                "thunar"
            ],
            "playback": [
                "mpv"
            ],
            "terminal": [
                "kitty"
            ]
        }
    },
    "launcher": {
        "favouriteApps": [
            "firefox",
            "obsidian",
            "spotify-launcher",
            "dev.warp.Warp",
            "spotify"
        ],
        "hiddenApps": [
            "bssh",
            "bvnc",
            "avahi-discover",
            "lstopo"
        ],
        "showOnHover": false
    },
    "paths": {
        "wallpaperDir": "~/Pictures/Wallpapers"
    },
    "services": {
        "gpuType": "amd"
    }
}
