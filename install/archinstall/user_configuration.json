{
  "version": "2.8.6",
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader_config": {
    "bootloader": "grub",
    "uki": false,
    "removable": false
  },
  "debug": false,
  "hostname": "archlinux",
  "kernels": [
    "linux"
  ],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "mirror_config": {
    "mirror_regions": {
      "Worldwide": [
        "https://geo.mirror.pkgbuild.com/$repo/os/$arch"
      ]
    },
    "optional_repositories": [
      "multilib"
    ],
    "custom_repositories": []
  },
  "network_config": {
    "type": "NetworkManager"
  },
  "no_pkg_lookups": false,
  "ntp": true,
  "offline": false,
  "packages": [
    "git",
    "curl",
    "wget",
    "neovim",
    "btrfs-progs",
    "amd-ucode"
  ],
  "parallel downloads": 5,
  "profile_config": {
    "profile": {
      "name": "minimal"
    }
  },
  "script": "guided",
  "silent": false,
  "swap": {
    "enabled": true,
    "algorithm": "zstd"
  },
  "timezone": "America/Santiago"
}